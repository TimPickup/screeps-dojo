# Host path to YOUR bot's script folder (flat .js modules). Mounted read-only at /bot.
DOJO_BOT_PATH=C:/path/to/your/screeps/scripts

# GUI server port (npm run ui). Published only to host loopback (127.0.0.1).
DOJO_UI_PORT=8787

# Accelerated Screeps MOCK engine. All optimizations are enabled by default.
# Set the master to 0 for stock multiprocess behavior, or override individual
# features with explicit 0/1 values (an unset individual inherits the master).
DOJO_FAST_MOCK_ENGINE=1
# DOJO_FAST_MOCK_ENGINE_RPC_V8=1
# DOJO_FAST_MOCK_ENGINE_CODE_CACHE=1
# DOJO_FAST_MOCK_ENGINE_ROOM_GUARD=1
# DOJO_FAST_MOCK_ENGINE_IN_PROCESS=1
# DOJO_FAST_MOCK_ENGINE_RESET_ACTIVE_ROOMS=1

# Engine backend for scenario runs (src/drivers.js). `mockup` =
# screeps-server-mockup (vanilla engine) — the default and currently the only one.
DOJO_ENGINE=mockup

# Room importer (npm run import-room)
# Auth: set DOJO_SCREEPS_TOKEN, OR — for a private server whose token is accepted
# over REST but rejected by the WebSocket (e.g. screepsmod-auth) — set
# DOJO_SCREEPS_USERNAME (or DOJO_SCREEPS_EMAIL) + DOJO_SCREEPS_PASSWORD instead.
DOJO_SCREEPS_TOKEN=
# DOJO_SCREEPS_USERNAME=
# DOJO_SCREEPS_PASSWORD=
DOJO_SCREEPS_HOSTNAME=screeps.com
DOJO_SCREEPS_PATH=/
DOJO_SCREEPS_PORT=443
DOJO_SCREEPS_PROTOCOL=https
DOJO_SCREEPS_SHARD=shard0
