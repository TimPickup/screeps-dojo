# Host path to YOUR bot's script folder (flat .js modules). Mounted read-only at /bot.
DOJO_BOT_PATH=C:/path/to/your/screeps/scripts

# GUI server port (npm run ui). Published only to host loopback (127.0.0.1).
DOJO_UI_PORT=8787

# Room importer (npm run import-room)
# Auth: set DOJO_SCREEPS_TOKEN, OR — for a private server whose token is accepted
# over REST but rejected by the WebSocket (e.g. screepsmod-auth) — set
# DOJO_SCREEPS_USERNAME (or DOJO_SCREEPS_EMAIL) + DOJO_SCREEPS_PASSWORD instead.
DOJO_SCREEPS_TOKEN=
# DOJO_SCREEPS_USERNAME=
# DOJO_SCREEPS_PASSWORD=
DOJO_SCREEPS_HOSTNAME=screeps.com
DOJO_SCREEPS_PATH=/
DOJO_SCREEPS_PORT=443
DOJO_SCREEPS_PROTOCOL=https
DOJO_SCREEPS_SHARD=shard0
