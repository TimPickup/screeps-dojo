+function getUserCode(userId) {
+    if(!dojoFeatures.isEnabled('codeCache')) {
+        return db['users.code'].findOne({$and: [{user: userId}, {activeWorld: true}]});
+    }
+
+    let entry = cachedUserCode.get(userId);
+    if(!entry) {
+        entry = {generation: 0, loading: null, loaded: false, value: null, subscribed: false};
+        cachedUserCode.set(userId, entry);
+    }
+    if(!entry.subscribed) {
+        common.storage.pubsub.subscribe(`user:${userId}/code`, () => {
+            entry.generation++;
+            entry.loading = null;
+            entry.loaded = false;
+            entry.value = null;
+        });
+        entry.subscribed = true;
+    }
+    if(entry.loaded) return q.when(entry.value);
+    if(entry.loading) return entry.loading;
+
+    const generation = entry.generation;
+    const loading = db['users.code'].findOne({$and: [{user: userId}, {activeWorld: true}]})
+        .then(doc => {
+            if(generation !== entry.generation) return getUserCode(userId);
+            entry.value = doc ? {
+                modules: Object.assign({}, doc.modules || {}),
+                timestamp: doc.timestamp
+            } : null;
+            entry.loaded = true;
+            return entry.value;
+        })
+        .finally(() => {
+            if(entry.loading === loading) entry.loading = null;
+        });
+    entry.loading = loading;
+    return loading;
+}
 
