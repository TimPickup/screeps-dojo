--- /dev/null
+++ b/dist/src/inProcessEngine.js
@@ -0,0 +1,74 @@
+"use strict";
+const q = require("q");
+const _ = require("lodash");
+const driver = require("@screeps/driver");
+const runner = require("@screeps/engine/src/runner");
+const processor = require("@screeps/engine/src/processor");
+
+async function runUsers(userIds) {
+    for (const userId of userIds) {
+        driver.config.emit("runnerLoopStage", "start");
+        try {
+            await runner.runUser(userId);
+        }
+        finally {
+            driver.config.emit("runnerLoopStage", "finish", userId);
+        }
+    }
+}
+
+async function runRoom(roomId) {
+    driver.config.emit("processorLoopStage", "start");
+    try {
+        const result = await q.all([
+            driver.getRoomIntents(roomId),
+            driver.getRoomObjects(roomId),
+            driver.getRoomTerrain(roomId),
+            driver.getGameTime(),
+            driver.getRoomInfo(roomId),
+            driver.getRoomFlags(roomId),
+        ]);
+        driver.config.emit("processorLoopStage", "getRoomData", roomId);
+        try {
+            driver.config.emit("processorLoopStage", "processRoom", roomId);
+            await processor.processRoom(roomId, {
+                intents: result[0],
+                roomObjects: result[1].objects,
+                users: result[1].users,
+                roomTerrain: result[2],
+                gameTime: result[3],
+                roomInfo: result[4],
+                flags: result[5],
+            });
+        }
+        catch (error) {
+            console.error("Error processing room " + roomId + ":", _.isObject(error) ? error.stack || error : error);
+        }
+        await driver.clearRoomIntents(roomId);
+    }
+    finally {
+        driver.config.emit("processorLoopStage", "finish", roomId);
+    }
+}
+
+async function runRooms(roomIds) {
+    for (const roomId of roomIds) await runRoom(roomId);
+}
+
+module.exports = {runUsers, runRooms, runRoom};
